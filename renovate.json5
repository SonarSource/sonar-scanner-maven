{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  extends: [ "github>SonarSource/renovate-config:quality-jvm-squad" ],
  ignorePaths: [
    "e2e/projects/**",
    "property-dump-plugin/**",
    "sonar-maven-plugin/src/it/**",
    "sonar-maven-plugin/src/test/projects/**",
  ],
  packageRules: [
    {
      matchPackageNames: [ "org.apache.maven:*" ],
      groupName: "Maven",
      groupSlug: "maven",
    },
    {
      matchPackageNames: [
        "org.apache.maven.plugin*"
      ],
      groupName: "Maven Plugins",
      groupSlug: "maven-plugins",
    },
  ],
}
